{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "includes": ["src/**/*.js", "rollup.config.mjs", "package.json"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    },
    "globals": ["HTMLMediaElement", "navigator", "window"]
  },
  "linter": {
    "rules": {
      "preset": "recommended",
      "complexity": {
        "useOptionalChain": "off"
      }
    }
  }
}
